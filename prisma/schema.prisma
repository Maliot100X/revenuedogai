generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id            String    @id @default(cuid())
  name          String
  ticker        String    @default("$RA")
  walletAddress String    @map("wallet_address")
  privateKey    String    @map("private_key")
  apiKey        String    @unique @map("api_key")
  description   String    @default("")
  avatarUrl     String?   @map("avatar_url")
  strategy      String    @default("")
  status        String    @default("active")
  pnlTotal      Float     @default(0) @map("pnl_total")
  pnl24h        Float     @default(0) @map("pnl_24h")
  tradeCount    Int       @default(0) @map("trade_count")
  winRate       Float     @default(0) @map("win_rate")
  balance       Float     @default(0)
  solBalance    Float     @default(0) @map("sol_balance")
  bountyCount   Int       @default(0) @map("bounty_count")
  taskCount     Int       @default(0) @map("task_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tokens        Token[]
  bounties      Bounty[]   @relation("BountyCreator")
  tasks         Task[]     @relation("TaskCreator")
  trades        Trade[]
  services      Service[]
  notifications Notification[]

  @@map("agents")
}

model Token {
  id              String    @id @default(cuid())
  agentId         String    @map("agent_id")
  agent           Agent     @relation(fields: [agentId], references: [id])
  name            String
  ticker          String
  contractAddress String?   @map("contract_address")
  mintAddress     String?   @map("mint_address")
  description     String    @default("")
  initialSupply   Float     @default(1000000) @map("initial_supply")
  price           Float     @default(0)
  marketCap       Float     @default(0) @map("market_cap")
  volume24h       Float     @default(0) @map("volume_24h")
  holders         Int       @default(0)
  status          String    @default("pending")
  launchedAt      DateTime? @map("launched_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("tokens")
}

model Bounty {
  id            String    @id @default(cuid())
  creatorId     String    @map("creator_id")
  creator       Agent     @relation("BountyCreator", fields: [creatorId], references: [id])
  title         String
  description   String
  rewardSol     Float     @map("reward_sol")
  rewardToken   String    @default("") @map("reward_token")
  status        String    @default("open")
  claimerId     String?   @map("claimer_id")
  winnerId      String?   @map("winner_id")
  submissionUrl String    @default("") @map("submission_url")
  deadline      DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("bounties")
}

model Task {
  id            String    @id @default(cuid())
  creatorId     String    @map("creator_id")
  creator       Agent     @relation("TaskCreator", fields: [creatorId], references: [id])
  agentId       String?   @map("agent_id")
  title         String
  description   String
  rewardSol     Float     @map("reward_sol")
  status        String    @default("open")
  claimerId     String?   @map("claimer_id")
  submissionUrl String    @default("") @map("submission_url")
  deadline      DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("tasks")
}

model Trade {
  id          String   @id @default(cuid())
  agentId     String   @map("agent_id")
  agent       Agent    @relation(fields: [agentId], references: [id])
  inputMint   String   @map("input_mint")
  outputMint  String   @map("output_mint")
  inputAmount Float    @map("input_amount")
  outputAmount Float   @map("output_amount")
  price       Float    @default(0)
  pnl         Float    @default(0)
  status      String   @default("completed")
  txSignature String   @default("") @map("tx_signature")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("trades")
}

model Service {
  id          String   @id @default(cuid())
  agentId     String   @map("agent_id")
  agent       Agent    @relation(fields: [agentId], references: [id])
  name        String
  description String   @default("")
  priceSol    Float    @default(0) @map("price_sol")
  category    String   @default("trading")
  status      String   @default("active")
  totalSold   Int      @default(0) @map("total_sold")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("services")
}

model FeeDistribution {
  id           String   @id @default(cuid())
  amountSol    Float    @map("amount_sol")
  source       String
  txSignature  String   @default("") @map("tx_signature")
  distributedAt DateTime @default(now()) @map("distributed_at")

  @@map("fee_distributions")
}

model Notification {
  id        String   @id @default(cuid())
  agentId   String   @map("agent_id")
  agent     Agent    @relation(fields: [agentId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}
